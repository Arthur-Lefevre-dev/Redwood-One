# ─────────────────────────────────────────────────────────
# Redwood Plus — variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs.
# NE JAMAIS commiter le fichier .env dans git.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=redwood
POSTGRES_USER=redwood
POSTGRES_PASSWORD=CHANGE_MOI_postgres

# ── Redis (Celery broker) ─────────────────────────────────
# Password is encoded automatically — do not paste a full redis:// URL here.
# With docker compose, REDIS_HOST must be the service name "redis", not localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_MOI_redis

# Relance auto des téléchargements torrent (scan Celery beat ~2 min).
TORRENT_AUTO_RETRY_ENABLED=true
TORRENT_AUTO_RETRY_MAX=5

# ── URLs de connexion ────────────────────────────────────
DATABASE_URL=postgresql://redwood:CHANGE_MOI_postgres@postgres:5432/redwood

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=CHANGE_MOI_cle_secrete_tres_longue_et_aleatoire
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Compte admin initial (créé par scripts/seed_admin.py) ─
ADMIN_USERNAME=admin
# Mot de passe bcrypt : max 72 octets (éviter une phrase trop longue).
ADMIN_PASSWORD=CHANGE_MOI_mdp_admin
ADMIN_EMAIL=admin@redwoodplus.local

# ── Métadonnées vidéo (TMDB et/ou IMDb API) ───────────────
# Fournisseur d’enrichissement à l’import : tmdb (défaut) ou imdbapi (https://imdbapi.dev — sans clé).
# METADATA_PROVIDER=tmdb
# IMDBAPI_BASE_URL=https://api.imdbapi.dev

# ── TMDB ──────────────────────────────────────────────────
# Inscription gratuite : https://www.themoviedb.org/settings/api
TMDB_API_KEY=votre_cle_tmdb_ici
# Mise en cache des bandes-annonces TMDB en base (réduit les appels /movie/{id}/videos). 0 = recharger à chaque visite.
TMDB_TRAILERS_CACHE_DAYS=7

# ── OVH Object Storage S3 ────────────────────────────────
S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
S3_ACCESS_KEY=votre_cle_s3_ovh
S3_SECRET_KEY=votre_secret_s3_ovh
S3_BUCKET_NAME=redwood-films
S3_REGION=gra

# ── Facturation (estimations admin — pas des factures légales) ─
# Stockage objet type OVH : € HT / (Gio·h) — utilisé pour coût récurrent catalogue (métadonnées taille_octets).
# BILLING_STORAGE_EUR_PER_GIB_HOUR_HT=0.00000972
# Taux indicatif USD → EUR pour borner les coûts Vast (VAST_MAX_DPH_PER_HOUR).
# BILLING_USD_TO_EUR=0.92
# Optionnel : € par minute de sortie pour transcodage local worker (0 = désactivé dans l’UI).
# BILLING_LOCAL_TRANSCODE_EUR_PER_MINUTE=0

# ── Upload direct ─────────────────────────────────────────
# Taille max en octets (défaut 50 GB)
MAX_UPLOAD_SIZE=53687091200

# ── Flower (monitoring Celery) ────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_MOI_flower

# ── Celery worker (Docker) ─────────────────────────────────
# Nombre de tâches en parallèle par **processus** worker (défaut 4 dans l’image).
# CELERY_WORKER_CONCURRENCY=4
# Pour lancer 10 workers Celery en parallèle (10 conteneurs sur la même file Redis) :
#   cd docker && docker compose up -d --scale worker=10
# (Le service worker n’a plus de container_name fixe pour permettre le scale.)

# ── CORS ──────────────────────────────────────────────────
# Séparer plusieurs origines par une virgule
ALLOWED_ORIGINS=http://localhost,https://redwoodplus.example.com

# ── Pub A-ADS (page lecture vidéo /watch/film.html) ────────
# https://a-ads.com — créer une unité « Acceptable Ads », copier l’id numérique du snippet (data-aa='…').
# La page film charge /api/public/watch-ads et injecte l’iframe si activé.
# WATCH_ADS_AADS_ENABLED=true
# WATCH_ADS_AADS_UNIT_ID=2437671
# Optionnel : unité « mobile » distincte pour la modale pub film (≤768px), ex. snippet A-ADS Adaptive mobile.
# Si vide, la même unité desktop est réutilisée avec mise en page iframe 70 % sur mobile.
# WATCH_ADS_AADS_MOBILE_UNIT_ID=2437679
# Bannière sticky connexion / inscription (autre unité A-ADS ; valeur = chiffres uniquement, ex. 2437672) :
# WATCH_ADS_AADS_AUTH_ENABLED=true
# WATCH_ADS_AADS_AUTH_UNIT_ID=2437672
# Optionnel : bandeau fixe en haut (≥769px) connexion / inscription — unité distincte, ex. 2437680.
# Si activé en même temps que la bannière bas, le bas n’apparaît que sur mobile ; le haut seulement sur grand écran.
# WATCH_ADS_AADS_AUTH_TOP_ENABLED=true
# WATCH_ADS_AADS_AUTH_TOP_UNIT_ID=2437680

# ── GPU (détection ffmpeg : API + worker Celery) ───────────
# auto (défaut) | amd | nvidia | intel | cpu
# Sur AMD sous Docker : monter /dev/dri sur le service worker (voir docker-compose.yml),
# reconstruire l’image worker (mesa-va-drivers), puis éventuellement :
# REDWOOD_GPU_VENDOR=amd
REDWOOD_GPU_VENDOR=

# ── Vast.ai (test — GPU à la demande) ──────────────────────
# Clé API : https://cloud.vast.ai/manage-keys/
# VAST_API_KEY=
# Optionnel : racine API (défaut https://console.vast.ai/api/v0)
# VAST_API_BASE_URL=https://console.vast.ai/api/v0
# Noms de GPU pour la recherche (GET /api/admin/vast/offers, script scripts/vast_smoke_test.py)
# GPU pour recherche d’offres / auto-pick Vast (noms = champ gpu_name de l’API).
# VAST_DEFAULT_GPU_NAMES=RTX 3060,RTX 4060,GTX 1070 Ti,RTX 3060 Ti,GTX 1080,RTX 3070,GTX 1060,Titan Xp,GTX 1080 Ti
# GPU « secondaires » encore utilisables (NVENC) ; GET /api/admin/vast/offers?gpu_tier=usable ou all
# VAST_USABLE_GPU_NAMES=GTX 1660,GTX 1660 SUPER,GTX 1660 S,GTX 1660 Ti,RTX 3050
# Plafonds pour POST /bundles/ : prix max ($/h, dph_total) et coût Internet max ($/To transféré ; l’API utilise $/Go, donc /1024)
# VAST_MAX_DPH_PER_HOUR=0.08
# VAST_MAX_BANDWIDTH_USD_PER_TB=4.0
# Débits min. hôte (Mb/s, champs inet_down / inet_up de l’API Vast). 0 = ne pas filtrer sur ce critère.
# VAST_MIN_INET_DOWN_MBPS=120
# VAST_MIN_INET_UP_MBPS=120
# Codes pays ISO (A2) exclus des offres Vast (ex. pas de machines en Chine). Vide = aucune exclusion.
# VAST_EXCLUDE_GEOLOCATION_CODES=CN
# Ne jamais auto-sélectionner les offres sur ces machine_id / host_id (tableau de bord Vast) — hôte bancal.
# Plusieurs valeurs : liste séparée par des virgules. L’ID de contrat d’instance change à chaque location.
# VAST_SKIP_MACHINE_IDS=48961
# VAST_SKIP_HOST_IDS=296571
# Image Docker sur l’instance Vast pour le test transcodage admin (onstart installe ffmpeg si runtime CUDA).
# VAST_TRANSCODE_DOCKER_IMAGE=nvidia/cuda:12.3.1-runtime-ubuntu22.04
# Capacités pilote injectées : « all » expose libnvidia-encode (NVENC). compute seul casse souvent NVENC sur Vast.
# VAST_TRANSCODE_NVIDIA_DRIVER_CAPABILITIES=all
# Indices GPU visibles dans le conteneur (contrat 1×GPU : « 0 »). « all » peut provoquer l’erreur CDI gpu=N sur l’hôte Vast.
# VAST_TRANSCODE_NVIDIA_VISIBLE_DEVICES=0
# Téléchargement d’un FFmpeg statique BtbN (NVENC récent, recommandé sur Vast). Chaîne vide = apt ffmpeg seul
# (souvent sans NVENC utilisable contre le pilote hôte malgré le GPU présent — préférer l’URL BtbN).
# VAST_TRANSCODE_BTBH_FFMPEG_URL=https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz
# Téléchargement source sur l’instance : connexions parallèles aria2c (1–32 ; défaut 16).
# VAST_TRANSCODE_INPUT_ARIA2_CONN=16
# VAST_TRANSCODE_INPUT_ARIA2_SPLIT=16
# VAST_TRANSCODE_DISK_GB=32
# VAST_TRANSCODE_URL_TTL_SEC=7200
# VAST_TRANSCODE_POLL_INTERVAL_SEC=15
# While waiting for the MP4 on S3, GET /instances/{id}/ at most every N seconds (404 / exited / offline → fail fast).
# VAST_TRANSCODE_INSTANCE_CHECK_SEC=60
# VAST_TRANSCODE_MAX_WAIT_SEC=7200
# Attente max (s) sur l’instance pour /dev/nvidia0 avant ffmpeg (attache GPU parfois après le boot).
# VAST_TRANSCODE_GPU_DEVICE_WAIT_SEC=90
# Si /dev/nvidia0 n’apparaît pas : destruction de l’instance et nouvelle offre (auto-pic), jusqu’à N essais.
# VAST_TRANSCODE_NO_GPU_MAX_RETRIES=6
# Si les logs Vast montrent « failed to inject CDI devices … gpu=N: unknown » : gardez
# VAST_TRANSCODE_NVIDIA_VISIBLE_DEVICES=0 (défaut Redwood) pour ne pas demander tous les GPU du nœud ; sinon autre offre / host.
# VAST_TRANSCODE_SINGLE_GPU_ONLY=true
# Si false, la recherche POST /bundles/ n’impose pas verified=true (inclut les machines « Unverified » Vast).
# VAST_BUNDLES_VERIFIED_ONLY=true

# ── Transcodage ffmpeg (fichiers non-MP4) ─────────────────
# Débit vidéo cible (kbit/s). 4000 ≈ 4 Mbit/s en moyenne. Max / buffer = pics VBV (ajuster ensemble).
# Pas de redimensionnement ni changement de FPS : résolution et images/s hérités du fichier source.
# TRANSCODE_VIDEO_BITRATE_KBPS=4000
# TRANSCODE_VIDEO_MAXRATE_KBPS=6000
# TRANSCODE_VIDEO_BUFSIZE_KBPS=12000
# Débit audio AAC (kbit/s) — transcodage local et Vast.
# TRANSCODE_AUDIO_BITRATE_KBPS=160

# Fichiers temp Docker (volume tmp_data → /tmp/redwood) : nettoyage après crash — scripts/cleanup_redwood_tmp.sh

# Inscription spectateurs sans code (true = dev uniquement)
REGISTRATION_OPEN=false

# Limite slowapi pour POST /api/auth/login (évite 429 en dev si trop de tests)
# AUTH_LOGIN_RATE_LIMIT=60/minute
