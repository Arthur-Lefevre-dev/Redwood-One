# ─────────────────────────────────────────────────────────
# Redwood Plus — variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs.
# NE JAMAIS commiter le fichier .env dans git.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=redwood
POSTGRES_USER=redwood
POSTGRES_PASSWORD=CHANGE_MOI_postgres

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_MOI_redis

# ── URLs de connexion (construites depuis les variables ci-dessus) ──
DATABASE_URL=postgresql://redwood:CHANGE_MOI_postgres@postgres:5432/redwood
REDIS_URL=redis://:CHANGE_MOI_redis@redis:6379/0

# ── JWT ───────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_MOI_cle_secrete_tres_longue_et_aleatoire
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Compte admin initial (créé par scripts/seed_admin.py) ─
ADMIN_USERNAME=admin
# Mot de passe bcrypt : max 72 octets (éviter une phrase trop longue).
ADMIN_PASSWORD=CHANGE_MOI_mdp_admin
ADMIN_EMAIL=admin@redwoodplus.local

# ── TMDB ──────────────────────────────────────────────────
# Inscription gratuite : https://www.themoviedb.org/settings/api
TMDB_API_KEY=votre_cle_tmdb_ici

# ── OVH Object Storage S3 ────────────────────────────────
S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
S3_ACCESS_KEY=votre_cle_s3_ovh
S3_SECRET_KEY=votre_secret_s3_ovh
S3_BUCKET_NAME=redwood-films
S3_REGION=gra

# ── Upload direct ─────────────────────────────────────────
# Taille max en octets (défaut 50 GB)
MAX_UPLOAD_SIZE=53687091200

# ── Flower (monitoring Celery) ────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_MOI_flower

# ── CORS ──────────────────────────────────────────────────
# Séparer plusieurs origines par une virgule
ALLOWED_ORIGINS=http://localhost,https://redwoodplus.example.com

# ── GPU (détection ffmpeg : API + worker Celery) ───────────
# auto (défaut) | amd | nvidia | intel | cpu
# Sur AMD sous Docker : monter /dev/dri sur le service worker (voir docker-compose.yml),
# reconstruire l’image worker (mesa-va-drivers), puis éventuellement :
# REDWOOD_GPU_VENDOR=amd
REDWOOD_GPU_VENDOR=

# Inscription spectateurs sans code (true = dev uniquement)
REGISTRATION_OPEN=false
